{
  "files.encoding": "utf8",
  "files.autoGuessEncoding": false,
  "terminal.integrated.env.windows": {
    "PYTHONUTF8": "1"
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell UTF-8": {
      "source": "PowerShell",
      "args": [
        "-NoExit",
        "-Command",
        "[Console]::InputEncoding=[System.Text.UTF8Encoding]::new($false); [Console]::OutputEncoding=[System.Text.UTF8Encoding]::new($false); $OutputEncoding=[Console]::OutputEncoding; chcp 65001 > $null"
      ]
    }
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell UTF-8"
}
